[
  {
    "label": "Compile C",
    "command": "bash",
    "args": ["-c", "'gcc -g \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\"'"],
    "use_new_terminal": false,
  },
  {
    "label": "Run C",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -g \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\" && \"$ZED_DIRNAME/$ZED_STEM.out\"'",
    ],
    "use_new_terminal": false,
  },
  {
    "label": "Run + Input C",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -g \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\" && \"$ZED_DIRNAME/$ZED_STEM.out\" < \"$ZED_DIRNAME/input.txt\" | tee \"$ZED_DIRNAME/output.txt\"'",
    ],
    "use_new_terminal": false,
  },
]
