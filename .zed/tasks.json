[
  {
    "label": "Compile C",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -Wall -Wextra -pedantic -g -Og \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\"'",
    ],
    "use_new_terminal": false,
  },
  {
    "label": "Run C",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -Wall -Wextra -pedantic -g -Og \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\" && \"$ZED_DIRNAME/$ZED_STEM.out\"'",
    ],
    "use_new_terminal": false,
  },
  {
    "label": "Run + Input C",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -Wall -Wextra -pedantic -g -Og \"$ZED_FILE\" -o \"$ZED_DIRNAME/$ZED_STEM.out\" && \"$ZED_DIRNAME/$ZED_STEM.out\" < \"$ZED_DIRNAME/input.txt\" | tee \"$ZED_DIRNAME/output.txt\"'",
    ],
    "use_new_terminal": false,
  },
  {
    "label": "Run C (Sanitazers)",
    "command": "bash",
    "args": [
      "-c",
      "'gcc -std=c17 -Wall -Wextra -pedantic -g -O1 -fsanitize=address,undefined \"${ZED_FILE}\" -o \"${ZED_DIRNAME}/${ZED_STEM}.san\" && \"${ZED_DIRNAME}/${ZED_STEM}.san\"'",
    ],
    "use_new_terminal": false,
  },
]
